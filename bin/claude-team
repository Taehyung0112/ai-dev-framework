#!/usr/bin/env bash
# claude-team — Agentic Workflow 2.2 management CLI
# Usage: claude-team <command> [options]
set -euo pipefail

# ─── Resolve framework root (the directory containing bin/)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FRAMEWORK_DIR="$(cd "${SCRIPT_DIR}/.." && pwd)"

# ─── Colour helpers
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
RESET='\033[0m'

pass()  { echo -e "  ${GREEN}[PASS]${RESET} $*"; }
warn()  { echo -e "  ${YELLOW}[WARN]${RESET} $*"; }
fail()  { echo -e "  ${RED}[FAIL]${RESET} $*"; }
info()  { echo -e "  ${BLUE}[INFO]${RESET} $*"; }
title() { echo -e "\n${BOLD}$*${RESET}"; }

# ══════════════════════════════════════════════════════════════
#  COMMAND: init
# ══════════════════════════════════════════════════════════════
cmd_init() {
  local global=0
  for arg in "$@"; do
    [[ "$arg" == "--global" ]] && global=1
  done

  title "claude-team init"

  # ── 1. Create .agents/ in current directory
  local target_dir="$(pwd)"
  local agents_dir="${target_dir}/.agents"

  if [[ ! -d "${agents_dir}" ]]; then
    mkdir -p "${agents_dir}"
    pass "Created ${agents_dir}"
  else
    info "${agents_dir} already exists — skipping mkdir"
  fi

  # ── 2. Write registry.json pointing at framework
  local registry="${agents_dir}/registry.json"
  if [[ ! -f "${registry}" ]]; then
    cat > "${registry}" << EOF
{
  "version": "2.0",
  "framework_path": "${FRAMEWORK_DIR}",
  "description": "Auto-generated by claude-team init. Points to shared ai-dev-framework.",

  "agent_definitions": {
    "base_path": "${FRAMEWORK_DIR}/agents/",
    "agents": {
      "pm":        "pm.md",
      "lead":      "lead.md",
      "architect": "architect.md",
      "coder":     "coder.md",
      "qa":        "qa.md",
      "auditor":   "auditor.md"
    }
  },

  "contracts": {
    "base_path": "${FRAMEWORK_DIR}/contracts/",
    "templates": {
      "task_card":            "TASK_CARD.md",
      "spec_sheet":           "SPEC_SHEET.md",
      "implementation_log":   "IMPLEMENTATION_LOG.md",
      "verification_report":  "VERIFICATION_REPORT.md"
    }
  },

  "playbook": {
    "base_path": "${FRAMEWORK_DIR}/playbook/",
    "files": {
      "claude_base":      "claude-base.md",
      "team_standards":   "team-standards.md",
      "architecture":     "architecture-guide.md",
      "testing":          "testing-guide.md",
      "git_workflow":     "git-workflow.md",
      "coding_standards": "coding-standards.md",
      "ai_workflow":      "ai-workflow.md",
      "pr_template":      "pr-template.md"
    }
  },

  "complexity_routing": {
    "L1": {
      "description": "Minor: docs, config, typo fix, dependency bump",
      "route": ["coder"],
      "gates": ["qa_smoke"],
      "coverage_threshold": null
    },
    "L2": {
      "description": "Feature: new logic, refactor, API change (non-safety-critical)",
      "route": ["architect", "coder", "qa"],
      "gates": ["architect_design", "qa_verification", "lead_gate"],
      "coverage_threshold": 0.80
    },
    "L3": {
      "description": "Critical: concurrency, financial, auth, production stability",
      "route": ["architect", "coder", "qa", "auditor"],
      "gates": ["architect_risk_assessment", "qa_verification", "auditor_signoff", "lead_gate"],
      "coverage_threshold": 0.90,
      "critical_path_threshold": 1.00
    }
  }
}
EOF
    pass "Created ${registry}"
  else
    info "${registry} already exists — skipping"
  fi

  # ── 3. Create team_status.md if missing
  local status_file="${agents_dir}/team_status.md"
  if [[ ! -f "${status_file}" ]]; then
    local today
    today="$(date +%Y-%m-%d)"
    cat > "${status_file}" << EOF
# Team Status Wall
<!-- Auto-updated by Lead Agent after every handoff. Do not edit manually. -->

**Project**: $(basename "${target_dir}")
**Last Updated**: ${today}
**Framework**: ${FRAMEWORK_DIR}

---

## Current Sprint

**Sprint Name**: \`sprint/initial\`
**Sprint Goal**: —
**Sprint Start**: ${today}
**Sprint End**: TBD

---

## Active Task

| Field | Value |
|---|---|
| Issue | — |
| Title | — |
| Complexity | — |
| Priority | — |
| Active Agent | **Lead** (awaiting first task) |
| Status | Idle — Ready for dispatch |

---

## Backlog

| Issue | Level | Priority | Title | Assigned Agent |
|---|---|---|---|---|
| — | — | — | *No tasks yet. Use \`開始新任務：[name]\` to create one.* | — |

---

## In Progress

| Issue | Level | Stage | Agent | Started |
|---|---|---|---|---|
| — | — | — | — | — |

---

## Done (This Sprint)

| Issue | Level | Title | Completed | Notes |
|---|---|---|---|---|
| — | — | *No completed tasks yet.* | — | — |

---

## Decision Log

| Timestamp | Agent | Decision | Rationale |
|---|---|---|---|
| ${today} | Lead | System initialized | claude-team init completed |

---

## Agent Roster

| Agent | File | Status |
|---|---|---|
| PM | \`${FRAMEWORK_DIR}/agents/pm.md\` | Ready |
| Lead | \`${FRAMEWORK_DIR}/agents/lead.md\` | Active |
| Architect | \`${FRAMEWORK_DIR}/agents/architect.md\` | Ready |
| Coder | \`${FRAMEWORK_DIR}/agents/coder.md\` | Ready |
| QA | \`${FRAMEWORK_DIR}/agents/qa.md\` | Ready |
| Auditor | \`${FRAMEWORK_DIR}/agents/auditor.md\` | Ready |
EOF
    pass "Created ${status_file}"
  else
    info "${status_file} already exists — skipping"
  fi

  # ── 4. Create .clauderules to activate Lead Agent at session start
  local clauderules="${target_dir}/.clauderules"
  if [[ ! -f "${clauderules}" ]]; then
    cat > "${clauderules}" << 'RULESEOF'
# Agentic Workflow 2.0 — Session Init Protocol
# Lead Agent activates automatically at the start of every Claude Code session.

At the start of every session, you are the Lead Agent.
Read `.agents/team_status.md` and report status in this exact format:

[LEAD] Session restored.
Sprint: {sprint_name} | Active Task: {issue_or_dash} | Active Agent: Lead
Last action: {last_decision_log_entry}
Awaiting: {next_step_or_"First task dispatch"}

To start a new task, use: 開始新任務：[description]
Agent definitions:  ~/.claude/framework/agents/
Contract templates: ~/.claude/framework/contracts/
RULESEOF
    pass "Created ${clauderules}"
  else
    info "${clauderules} already exists — skipping"
  fi

  # ── 5. Global setup (--global flag)
  if [[ "${global}" == "1" ]]; then
    title "Global setup"

    # Symlink ~/.claude/framework → ai-dev-framework
    local claude_dir="${HOME}/.claude"
    local link_target="${claude_dir}/framework"

    if [[ -L "${link_target}" ]]; then
      info "Symlink ${link_target} already exists — updating"
      rm "${link_target}"
    fi

    ln -s "${FRAMEWORK_DIR}" "${link_target}"
    pass "Symlink: ${link_target} → ${FRAMEWORK_DIR}"

    # Update ~/.claude/CLAUDE.md to import from framework/playbook/
    local claude_md="${claude_dir}/CLAUDE.md"
    local import_marker="<!-- managed-by: claude-team v2.1 -->"

    if [[ -f "${claude_md}" ]] && grep -q "${import_marker}" "${claude_md}" 2>/dev/null; then
      info "CLAUDE.md already up to date (v2.1 marker found) — skipping"
    else
      if [[ -f "${claude_md}" ]]; then
        # Strip stale v2.0 managed block before re-writing
        cp "${claude_md}" "${claude_md}.bak"
        perl -i -0pe \
          's/\n## Agentic Workflow 2\.[^\n]*\n(?:.*\n)*?@~\/\.claude\/framework\/playbook\/pr-template\.md\n//g' \
          "${claude_md}" 2>/dev/null || true
      else
        printf '# Global Claude Configuration\n' > "${claude_md}"
      fi

      cat >> "${claude_md}" << MDEOF

## Agentic Workflow 2.1 Framework
${import_marker}
@~/.claude/framework/agents/lead.md
@~/.claude/framework/agents/context_controller.md
@~/.claude/framework/playbook/claude-base.md
@~/.claude/framework/playbook/team-standards.md
@~/.claude/framework/playbook/architecture-guide.md
@~/.claude/framework/playbook/testing-guide.md
@~/.claude/framework/playbook/git-workflow.md
@~/.claude/framework/playbook/coding-standards.md
@~/.claude/framework/playbook/ai-workflow.md
@~/.claude/framework/playbook/pr-template.md
MDEOF
      pass "Updated ${claude_md} with v2.1 framework imports"
    fi
  fi

  echo ""
  pass "Init complete. Start Claude Code and the Lead Agent will greet you."

  # Auto-run doctor after global setup so the user sees their environment state
  if [[ "${global}" == "1" ]]; then
    echo ""
    cmd_doctor
  fi
}

# ══════════════════════════════════════════════════════════════
#  COMMAND: update  (ADR-007: monorepo-aware)
# ══════════════════════════════════════════════════════════════
cmd_update() {
  title "claude-team update"

  # ── ADR-007 fix: ai-dev-framework may live inside a monorepo (no .git of its own).
  # Walk up from FRAMEWORK_DIR to find the actual git root, then pull from there.
  local git_root
  git_root="$(git -C "${FRAMEWORK_DIR}" rev-parse --show-toplevel 2>/dev/null)" || {
    fail "No git repository found at or above ${FRAMEWORK_DIR}. Cannot update."
    exit 1
  }

  if [[ "${git_root}" == "${FRAMEWORK_DIR}" ]]; then
    info "Standalone repo: ${git_root}"
  else
    info "Monorepo detected: git root is ${git_root}"
    info "Framework lives at: ${FRAMEWORK_DIR}"
  fi

  info "Pulling latest (--ff-only)..."
  git -C "${git_root}" pull --ff-only

  pass "Framework updated. Restart Claude Code to apply changes."
}

# ══════════════════════════════════════════════════════════════
#  COMMAND: status
# ══════════════════════════════════════════════════════════════
cmd_status() {
  title "claude-team status — Sprint Dashboard"

  # ── Locate team_status.md: CWD/.agents/ first, then FRAMEWORK_DIR/.agents/
  local status_file=""
  if [[ -f "$(pwd)/.agents/team_status.md" ]]; then
    status_file="$(pwd)/.agents/team_status.md"
  elif [[ -f "${FRAMEWORK_DIR}/.agents/team_status.md" ]]; then
    status_file="${FRAMEWORK_DIR}/.agents/team_status.md"
  else
    warn "No .agents/team_status.md found in $(pwd) or ${FRAMEWORK_DIR}"
    warn "Run: claude-team init"
    exit 1
  fi

  # ── Parse header fields
  local project last_updated
  project="$(grep -m1 '^\*\*Project\*\*' "${status_file}" | sed 's/\*\*Project\*\*: //' | xargs)"
  last_updated="$(grep -m1 '^\*\*Last Updated\*\*' "${status_file}" | sed 's/\*\*Last Updated\*\*: //' | xargs)"

  # ── Parse sprint fields
  local sprint_name sprint_goal sprint_start sprint_end
  sprint_name="$(grep -m1 '^\*\*Sprint Name\*\*' "${status_file}" | sed "s/.*\`\(.*\)\`.*/\1/" | xargs)"
  sprint_goal="$(grep -m1 '^\*\*Sprint Goal\*\*' "${status_file}" | sed 's/\*\*Sprint Goal\*\*: //' | xargs)"
  sprint_start="$(grep -m1 '^\*\*Sprint Start\*\*' "${status_file}" | sed 's/\*\*Sprint Start\*\*: //' | xargs)"
  sprint_end="$(grep -m1 '^\*\*Sprint End\*\*' "${status_file}" | sed 's/\*\*Sprint End\*\*: //' | xargs)"

  # ── Parse active task (extract rows between ## Active Task and next ---)
  local active_issue active_title active_agent active_status
  active_issue="$(awk '/^## Active Task/{f=1} f && /^\| Issue/{print; exit} /^---/{f=0}' "${status_file}" \
    | sed 's/| Issue *| *//' | tr -d '|' | xargs)"
  active_title="$(awk '/^## Active Task/{f=1} f && /^\| Title/{print; exit} /^---/{f=0}' "${status_file}" \
    | sed 's/| Title *| *//' | tr -d '|' | xargs)"
  active_agent="$(awk '/^## Active Task/{f=1} f && /^\| Active Agent/{print; exit} /^---/{f=0}' "${status_file}" \
    | sed 's/| Active Agent *| *//' | tr -d '|' | xargs)"
  active_status="$(awk '/^## Active Task/{f=1} f && /^\| Status/{print; exit} /^---/{f=0}' "${status_file}" \
    | sed 's/| Status *| *//' | tr -d '|' | xargs)"

  # ── Count backlog / in-progress / done rows (rows that start with | # or | local-)
  local backlog_count inprogress_count done_count
  backlog_count="$(awk '/^## Backlog/{f=1;next} /^## In Progress/{f=0} f && /^\| [^-|]/{c++} END{print c+0}' "${status_file}")"
  inprogress_count="$(awk '/^## In Progress/{f=1;next} /^## Done/{f=0} f && /^\| [^-|]/{c++} END{print c+0}' "${status_file}")"
  done_count="$(awk '/^## Done/{f=1;next} /^## Decision/{f=0} f && /^\| [^-|]/{c++} END{print c+0}' "${status_file}")"

  # ── Display
  echo ""
  echo -e "  ${BOLD}Project${RESET}:      ${project:----}"
  echo -e "  ${BOLD}Updated${RESET}:      ${last_updated:----}"
  echo ""
  echo -e "  ${BLUE}Sprint${RESET}:   ${sprint_name:----}"
  echo -e "  ${BLUE}Goal${RESET}:     ${sprint_goal:----}"
  echo -e "  ${BLUE}Period${RESET}:   ${sprint_start:----} → ${sprint_end:----}"
  echo ""
  echo -e "  ┌─ ${BOLD}Active Task${RESET}"
  echo -e "  │  Issue:  ${active_issue:----}"
  echo -e "  │  Title:  ${active_title:----}"
  echo -e "  │  Agent:  ${active_agent:----}"
  echo -e "  └─ Status: ${active_status:----}"
  echo ""
  echo -e "  ${YELLOW}Backlog${RESET}:      ${backlog_count} items"
  echo -e "  ${BLUE}In Progress${RESET}: ${inprogress_count} items"
  echo -e "  ${GREEN}Done${RESET}:         ${done_count} items (this sprint)"
  echo ""
  info "Source: ${status_file}"
}

# ══════════════════════════════════════════════════════════════
#  COMMAND: doctor
# ══════════════════════════════════════════════════════════════
cmd_doctor() {
  title "claude-team doctor — Environment Diagnostics"
  local issues=0

  # ── gh
  if command -v gh &>/dev/null; then
    local gh_ver
    gh_ver="$(gh --version 2>&1 | head -1)"
    pass "gh: ${gh_ver}"
    if gh auth status &>/dev/null; then
      pass "gh auth: authenticated"
    else
      warn "gh auth: NOT authenticated — run: gh auth login"
      ((issues++)) || true
    fi
  else
    fail "gh: not found — install from https://cli.github.com"
    ((issues++)) || true
  fi

  # ── python3
  if command -v python3 &>/dev/null; then
    local py_ver
    py_ver="$(python3 --version 2>&1)"
    pass "python3: ${py_ver}"
  else
    fail "python3: not found — required for SDK tests (use python3, NOT python)"
    ((issues++)) || true
  fi

  # ── pip3
  if command -v pip3 &>/dev/null; then
    local pip_ver
    pip_ver="$(pip3 --version 2>&1 | head -1)"
    pass "pip3: ${pip_ver}"
  else
    warn "pip3: not found — needed to install Python dependencies"
    ((issues++)) || true
  fi

  # ── pytest
  if command -v pytest &>/dev/null || python3 -m pytest --version &>/dev/null 2>&1; then
    pass "pytest: available"
  else
    warn "pytest: not found — run: pip3 install pytest pytest-cov"
    ((issues++)) || true
  fi

  # ── node
  if command -v node &>/dev/null; then
    local node_ver
    node_ver="$(node --version 2>&1)"
    pass "node: ${node_ver}"
  else
    warn "node: not found — required for TypeScript tooling (cert-server-rest, etc.)"
    ((issues++)) || true
  fi

  # ── vcpkg
  if command -v vcpkg &>/dev/null; then
    pass "vcpkg: found"
  elif [[ -f "${HOME}/vcpkg/vcpkg" ]] || [[ -f "/c/vcpkg/vcpkg.exe" ]]; then
    pass "vcpkg: found (not in PATH but binary exists)"
  else
    warn "vcpkg: not found — required for C++ SDK builds"
    ((issues++)) || true
  fi

  # ── git
  if command -v git &>/dev/null; then
    local git_ver
    git_ver="$(git --version 2>&1)"
    pass "git: ${git_ver}"
  else
    fail "git: not found — install git"
    ((issues++)) || true
  fi

  # ── Framework link (symlink on Unix, directory junction on Windows)
  local fw_link="${HOME}/.claude/framework"
  if [[ -L "${fw_link}" ]]; then
    local link_dest
    link_dest="$(readlink "${fw_link}")"
    pass "~/.claude/framework: symlink → ${link_dest}"
  elif [[ -d "${fw_link}" ]]; then
    # Windows directory junction — verify it points to this framework
    if [[ -f "${fw_link}/README.md" ]]; then
      pass "~/.claude/framework: junction → ${fw_link} (content verified)"
    else
      warn "~/.claude/framework: directory exists but looks empty — re-run: claude-team init --global"
      ((issues++)) || true
    fi
  else
    warn "~/.claude/framework: missing — run: claude-team init --global"
    ((issues++)) || true
  fi

  # ── team_status.md
  if [[ -f "$(pwd)/.agents/team_status.md" ]]; then
    pass ".agents/team_status.md: present"
  else
    warn ".agents/team_status.md: missing in $(pwd) — run: claude-team init"
    ((issues++)) || true
  fi

  echo ""
  if [[ "${issues}" -eq 0 ]]; then
    pass "All checks passed. Environment is ready."
  else
    warn "${issues} issue(s) found. Resolve warnings before starting work."
  fi
}

# ══════════════════════════════════════════════════════════════
#  COMMAND: help
# ══════════════════════════════════════════════════════════════
cmd_help() {
  cat << 'EOF'

  claude-team — Agentic Workflow 2.1 CLI

  USAGE:
    claude-team <command> [options]

  COMMANDS:
    init [--global]   Initialise agent workflow in current directory.
                      --global: also create ~/.claude/framework symlink
                                and update ~/.claude/CLAUDE.md imports.

    update            Pull latest framework changes from git remote.
                      Supports monorepo layout (ADR-007): walks up to git root.

    status            Display current sprint dashboard from .agents/team_status.md.

    doctor            Diagnose environment (gh, python3, node, vcpkg, git,
                      symlink, team_status.md).

    help              Show this help text.

  EXAMPLES:
    # First-time setup (run once per machine)
    claude-team init --global

    # Attach framework to a new project repo
    cd ~/incubator/order-hub
    claude-team init

    # Show current sprint status
    claude-team status

    # Sync latest playbook changes from team
    claude-team update

    # Verify environment before starting work
    claude-team doctor

EOF
}

# ══════════════════════════════════════════════════════════════
#  DISPATCH
# ══════════════════════════════════════════════════════════════
CMD="${1:-help}"
shift || true

case "${CMD}" in
  init)    cmd_init "$@" ;;
  update)  cmd_update "$@" ;;
  status)  cmd_status "$@" ;;
  doctor)  cmd_doctor "$@" ;;
  help|--help|-h) cmd_help ;;
  *)
    echo -e "${RED}Unknown command: ${CMD}${RESET}"
    cmd_help
    exit 1
    ;;
esac
