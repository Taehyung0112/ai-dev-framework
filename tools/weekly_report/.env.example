# ══════════════════════════════════════════════════════
#  週報自動填寫腳本 — 個人設定檔
#  複製此檔案並填入個人資訊:
#    cp .env.example .env
#    source .env          # 或寫入 ~/.bashrc 永久生效
# ══════════════════════════════════════════════════════

# ── 必填：你的 Claude API Key ─────────────────────────
# 用於智慧摘要 git commit；沒有則退回規則分組
ANTHROPIC_API_KEY=sk-ant-...

# ── 必填：你在工作日誌系統的員工 ID ──────────────────
# 這是 NocoDB「人員表」裡你的記錄 ID（整數）
# 作用：讓週報的「回報人」欄位顯示你的名字
# 查詢方式：python weekly_report.py --list-people
NOCODB_PEOPLE_ID=0

# ── 必填：你本機的 git repo 路徑 ─────────────────────
# 腳本會掃描這些 repo 的本週 commit
# 多個 repo 用分號分隔
# Windows 範例: C:/Users/yourname/incubator
# Linux 範例:   /home/yourname/incubator
GIT_REPOS=C:/Users/yourname/incubator

# ── 選填：NocoDB API Token ────────────────────────────
# 全團隊共用同一個 token，已內建預設值
# 只有在 token 輪換時才需要更新此項
# 注意：這不是工作日誌網站的帳號密碼，
#       腳本直接走 REST API，不需要網站登入
# NOCODB_XC_TOKEN=
